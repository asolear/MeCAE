// components/NavigationBar.js
import React, { useState } from 'react';
import { AppBar, Toolbar, Button, Box } from '@mui/material';
import { Link } from 'react-router-dom';
import EnergySavingsLeafOutlinedIcon from '@mui/icons-material/EnergySavingsLeafOutlined';

const NavigationBar = () => {


    const [activeLink, setActiveLink] = useState(window.location.pathname);

    const handleLinkClick = (path) => {
        setActiveLink(path);
    };

    return (
        <AppBar position="static" sx={{ bgcolor: 'white', color: 'black' }}>
            <Toolbar>
                <Button
                    color="inherit"
                    component={Link}
                    to="/"
                    onClick={() => handleLinkClick('/')}
                    sx={{
                        color: activeLink === '/' ? 'black' : 'gray',
                        fontWeight: activeLink === '/' ? 'bold' : 'normal',
                    }}
                >
                    <EnergySavingsLeafOutlinedIcon sx={{ color: activeLink === '/' ? 'black' : 'gray' }} />
                </Button>

                <Button
                    color="inherit"
                    component={Link}
                    to="/Ahorros"
                    onClick={() => handleLinkClick('/Ahorros')}
                    sx={{
                        color: activeLink === '/Ahorros' ? 'black' : 'gray',
                        fontWeight: activeLink === '/Ahorros' ? 'bold' : 'normal',
                    }}
                >
                    Ahorros
                </Button>


                <Button
                    color="inherit"
                    component={Link}
                    to="/Informes"
                    onClick={() => handleLinkClick('/Informes')}
                    sx={{
                        color: activeLink === '/Informes' ? 'black' : 'gray',
                        fontWeight: activeLink === '/Informes' ? 'bold' : 'normal',
                    }}
                >
                    Informes
                </Button>

                <Button
                    color="inherit"
                    component={Link}
                    to="/contacto"
                    onClick={() => handleLinkClick('/contacto')}
                    sx={{
                        color: activeLink === '/contacto' ? 'black' : 'gray',
                        fontWeight: activeLink === '/contacto' ? 'bold' : 'normal',
                    }}
                >
                    Contacto
                </Button>
                {/*  */}
                <Box sx={{ textAlign: "center", margin: 2 }}>
                    <Link to="/register">
                        <Button variant="outlined" sx={{ mx: 1 }}>
                            Registro
                        </Button>
                    </Link>
                    <Link to="/login">
                        <Button variant="outlined" sx={{ mx: 1 }}>
                            Iniciar Sesión
                        </Button>
                    </Link>
                </Box>
                {/*  */}


            </Toolbar>
        </AppBar>
    );
};

export default NavigationBar;
